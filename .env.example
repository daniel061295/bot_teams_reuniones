# ── Groq API (transcripción en nube, ultrarrápida, gratis) ─────────────────────────────
# Obten tu clave gratuita en: https://console.groq.com
# Si no esta definida, el bot usara faster-whisper local como respaldo.
GROQ_API_KEY=gsk_tu_api_key_aqui

# ── Google Gemini API Key (requerida para generar minutas) ──────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Whisper local (fallback cuando Groq falla o no está configurado) ──────────────
# Modelos disponibles: tiny, base, small, medium, large-v2, large-v3
# medium = buen balance velocidad/precisión para CPU
WHISPER_MODEL=medium

# ── Directorios de salida ─────────────────────────────────────────────────
OUTPUT_DIR=outputs
MINUTAS_DIR=minutas
